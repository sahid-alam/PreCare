# =========================
# Supabase
# =========================
# Project URL — Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Anon public key — Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — Settings → API → service_role
# SERVER ONLY. Never imported into client code.
SUPABASE_SERVICE_ROLE_KEY=

# =========================
# Vapi
# =========================
# Public key — Vapi dashboard → Account → API Keys → Public Key
# Safe to expose to the browser; used by the Web SDK.
NEXT_PUBLIC_VAPI_PUBLIC_KEY=

# Assistant ID — created in the Vapi dashboard. See docs/vapi-setup.md.
NEXT_PUBLIC_VAPI_ASSISTANT_ID=

# Webhook signing secret — Vapi dashboard → Assistant → Server URL Secret
# Used in /api/vapi/webhook to verify incoming events.
VAPI_WEBHOOK_SECRET=

# =========================
# App
# =========================
# Public-facing URL of this deployment (used for webhook URL display, logging).
NEXT_PUBLIC_APP_URL=http://localhost:3000
